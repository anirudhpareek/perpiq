		"tailwind-variants": "^3.2.2",
		"tailwindcss": "^4.1.18",
		"tsx": "^4.21.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.54.0",
		"vaul-svelte": "^1.0.0-next.7",
		"vite": "^7.3.1"
	},
	"dependencies": {
		"@nktkas/hyperliquid": "^0.31.0",
		"@paper-design/shaders": "^0.0.71",
		"@prisma/adapter-pg": "^7.3.0",
		"@prisma/client": "^7.3.0",
		"@sveltejs/adapter-vercel": "^6.3.1",
